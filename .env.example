# Environment Variables — FindUS Backend
# Copy this file to .env and fill in your own values
# Never commit .env to git

PORT=5000

# MongoDB connection string
# Local:   mongodb://localhost:27017/findus
# Atlas:   mongodb+srv://<username>:<password>@cluster.mongodb.net/findus
MONGO_URI=mongodb://localhost:27017/findus

# JWT secret — make this long and random in production
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
